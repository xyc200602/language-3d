@inproceedings{text2robot2025,
  author={Ringel, M. and Chen, Y. and others},
  title={Text2Robot: From Text Commands to Cost-Effective 3D-Printed
         Legged Robots},
  booktitle={IEEE International Conference on Robotics and Automation
             (ICRA)},
  year={2025},
  note={Verified: arXiv:2406.19963 + project page
        (generalroboticslab.com/Text2Robot) + Duke Pratt School news.
        Text + performance preferences → 3D mesh → kinematic structure →
        URDF → RL gait evolution → 3D-printed + real servos → walking in
        ~1 day. Overlaps L3D on NL/URDF/sim, but only quadrupeds (no
        arms/grippers/grasp/BOM/firmware); has physical hardware (L3D
        does not). Must be cited for novelty defense.}
}

