# Language-3D Agent Configuration
# Copy this file to .env and fill in your API keys

# GLM (Zhipu AI) - Primary model backend (Coding Plan API)
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
GLM_MODEL=GLM-5.1

# Vision model for screen analysis (used by GLM backend)
VISION_MODEL=GLM-5V-Turbo

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Ollama local models (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Agent settings
AGENT_MAX_TURNS=50
AGENT_WORKSPACE=./data/projects

# Simulation settings (optional)
# CALCULIX_PATH=C:\Program Files\FreeCAD 1.1\bin\ccx.exe
# DEFAULT_SIM_MATERIAL=steel
# DEFAULT_SLICE_MATERIAL=pla

# CFD settings (optional)
# OPENFOAM_PATH=/opt/openfoam11
# OPENFOAM_MODE=auto  # auto, wsl, native, docker
